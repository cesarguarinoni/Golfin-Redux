  rows:
  - key: BTN_LOADING
    english: NOW LOADING
    japanese: "\u8AAD\u307F\u8FBC\u307F\u4E2D"
  - key: BTN_START
    english: PLAY
    japanese: "\u30D7\u30EC\u30A4"
  - key: BTN_CREATE
    english: CREATE ACCOUNT
    japanese: "\u30A2\u30AB\u30A6\u30F3\u30C8\u4F5C\u6210"
  - key: BTN_LOGIN
    english: LOGIN
    japanese: "\u30ED\u30B0\u30A4\u30F3"
  - key: TIP_HEADER
    english: PRO TIP
    japanese: "\u30D7\u30ED\u306E\u30D2\u30F3\u30C8"
  - key: TIP_NEXT
    english: TAP FOR NEXT TIP
    japanese: "\u30BF\u30C3\u30D7\u3057\u3066\u6B21\u3078"
  - key: TIP_CLUB
    english: HOLD THE CLUB BALL BUTTON TO ENTER YOUR BAGS IN-GAME
    japanese: "\u30AF\u30E9\u30D6\u30DC\u30BF\u30F3\u9577\u62BC\u3057\u3067\u30D0\u30C3\u30B0\u3092\u958B\u304F"
  - key: TIP_FORECAST
    english: LANDINGFORECAST  DOES NOT FACTOR THE BALL'S RUN OR WIND. COMPENSATE
      ACCORDINGLY
    japanese: "\u7740\u5730\u4E88\u6E2C\u306B\u306F\u30DC\u30FC\u30EB\u306E\u8EE2\u304C\u308A\u3068\u98A8\u306F\u542B\u307E\u308C\u307E\u305B\u3093"
  - key: TIP_RARITIES
    english: DIFFERENT RARITIES  BESTOW DIFFERENT INITIAL STATS  AND MAX LEVEL
    japanese: "\u30EC\u30A2\u5EA6\u306B\u3088\u3063\u3066\u521D\u671F\u30B9\u30C6\u30FC\u30BF\u30B9\u3068\u6700\u5927\u30EC\u30D9\u30EB\u304C\u7570\u306A\u308A\u307E\u3059"
  - key: TIP_SWING
    english: PULL  THE CLUB BACK THEN FLICK  IT FORWARD TO SWING
    japanese: "\u30AF\u30E9\u30D6\u3092\u5F15\u3044\u3066\u524D\u306B\u5F3E\u3044\u3066\u30B9\u30A4\u30F3\u30B0"
  - key: TIP_ACCURACY
    english: FLICKER  THROUGH THE BALL FOR PERFECT ACCURACY
    japanese: "\u30DC\u30FC\u30EB\u3092\u901A\u904E\u3055\u305B\u308B\u3068\u5B8C\u74A7\u306A\u7CBE\u5EA6"
  - key: TIP_LEADERBOARD
    english: LOOK FOR THESE ICONS IN LEADERBOARDS  FOR LONGEST SHOTS
    japanese: "\u30EA\u30FC\u30C0\u30FC\u30DC\u30FC\u30C9\u3067\u3053\u308C\u3089\u306E\u30A2\u30A4\u30B3\u30F3\u3092\u63A2\u3057\u3066\u6700\u9577\u30B7\u30E7\u30C3\u30C8"
  - key: TIP_TIMING
    english: HIT THE BALL WHEN HIGHLIGHTED  FOR A PERFECT SHOT
    japanese: "\u30CF\u30A4\u30E9\u30A4\u30C8\u6642\u306B\u30DC\u30FC\u30EB\u3092\u6253\u3064\u3068\u5B8C\u74A7\u306A\u30B7\u30E7\u30C3\u30C8"
  - key: TIP_VIEW
    english: DOUBLE TAP TO SWITCH BETWEEN SHOT VIEW AND MAP VIEW
    japanese: "\u30C0\u30D6\u30EB\u30BF\u30C3\u30D7\u3067\u30B7\u30E7\u30C3\u30C8\u30D3\u30E5\u30FC\u3068\u30DE\u30C3\u30D7\u30D3\u30E5\u30FC\u3092\u5207\u308A\u66FF\u3048"
  - key: HOME_CURRENCY_LABEL
    english: COINS
    japanese: "\u30B3\u30A4\u30F3"
  - key: HOME_USERNAME
    english: USERNAME
    japanese: "\u30E6\u30FC\u30B6\u30FC\u540D"
  - key: HOME_MAINTENANCE_TITLE
    english: MAINTENANCE NOTICE
    japanese: "\u30E1\u30F3\u30C6\u30CA\u30F3\u30B9\u60C5\u5831"
  - key: HOME_MAINTENANCE_BODY
    english: 'Scheduled server maintenance: 2025/12/31\nThe game will not be available
      for a short time\nduring maintenance.'
    japanese: "\u5B9A\u671F\u30B5\u30FC\u30D0\u30FC\u30E1\u30F3\u30C6\u30CA\u30F3\u30B9:
      2025/12/31\\n\u30E1\u30F3\u30C6\u30CA\u30F3\u30B9\u4E2D\u306F\u30B2\u30FC\u30E0\u3092\u3054\u5229\u7528\u3044\u305F\u3060\u3051\u307E\u305B\u3093\u3002"
  - key: HOME_GPS_TITLE
    english: "GOLFIN\xB7GPS"
